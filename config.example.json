{
  "version": 1,
  "defaults": {
    "mode": "run",
    "outputDir": "./data",
    "logLevel": "info"
  },
  "sources": {
    "credentialFiles": {
      "search": "C:/Users/bing/.openclaw/credentials/search.json",
      "openclaw": "C:/Users/bing/.openclaw/openclaw.json"
    }
  },
  "fetch": {
    "activeProfile": "grok-default",
    "profiles": {
      "grok-default": {
        "providerRef": "grok",
        "timeoutMs": 60000,
        "retry": {
          "maxAttempts": 3,
          "backoffMs": 1500
        },
        "concurrency": 4,
        "batchSize": 3,
        "refetchOnStatuses": ["incomplete", "fetch_failed", "soft_failed"],
        "refetchMaxRounds": 3,
        "refetchBatchSize": 3,
        "refetchConcurrency": 4,
        "timeWindowHours": 24,
        "includeTweetTypes": ["original", "repost", "quote"],
        "excludePureReplies": true,
        "seedCsvPath": "./X列表关注者.daily.csv",
        "promptFile": "assets/prompts/grok-fetch.txt",
        "precheck": {
          "enabled": true,
          "staticFilterZeroPosts": true,
          "dormantThresholdDays": 7,
          "batchSize": 10,
          "timeoutMs": 30000,
          "maxOutputTokens": 500,
          "promptFile": "assets/prompts/grok-precheck.txt"
        }
      }
    }
  },
  "roster": {
    "enabled": true,
    "masterCsvPath": "./X列表关注者.csv",
    "dailyCsvPath": "./X列表关注者.daily.csv",
    "scoreFilePath": "./account-score.json",
    "scoring": {
      "enabled": true,
      "promptFile": "assets/prompts/gpt-roster-score.txt",
      "batchSize": 20,
      "maxTweetsPerAccount": 3,
      "defaultScore": 2,
      "minScore": 0,
      "maxScore": 5,
      "dailyMinScore": 4,
      "everyOtherDayMinScore": 2,
      "weeklyMinScore": 1,
      "dailyIntervalDays": 1,
      "everyOtherDayIntervalDays": 2,
      "weeklyIntervalDays": 7,
      "coldIntervalDays": 28
    }
  },
  "analysis": {
    "activeProfile": "gpt-default",
    "profiles": {
      "gpt-default": {
        "providerRef": "gpt",
        "modelRef": "gpt-main",
        "rosterModelRef": "gpt-main-mini",
        "screeningModelRef": "gpt-main-mini",
        "apiProtocol": "openai-compatible",
        "timeoutMs": 180000,
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 2500
        },
        "concurrency": 1,
        "temperature": 0.2,
        "maxOutputTokens": 8000,
        "maxContinuations": 2,
        "promptFile": "assets/prompts/gpt-analyze.txt"
      },
      "claude-default": {
        "providerRef": "claude",
        "modelRef": "claude-main",
        "apiProtocol": "openai-compatible",
        "timeoutMs": 180000,
        "retry": {
          "maxAttempts": 2,
          "backoffMs": 2500
        },
        "concurrency": 1,
        "temperature": 0.2,
        "maxOutputTokens": 8000,
        "maxContinuations": 2,
        "promptFile": "assets/prompts/gpt-analyze.txt"
      }
    }
  },
  "providers": {
    "grok": {
      "role": "fetch",
      "configSource": {
        "fileRef": "search",
        "jsonPath": "$.grok"
      },
      "mapping": {
        "baseUrl": "apiUrl",
        "apiKey": "apiKey",
        "defaultModel": "model"
      }
    },
    "gpt": {
      "role": "analysis",
      "configSource": {
        "fileRef": "openclaw",
        "jsonPath": "$.models.providers.router-gpt"
      },
      "mapping": {
        "baseUrl": "baseUrl",
        "apiKey": "apiKey",
        "api": "api",
        "headers": "headers",
        "authHeader": "authHeader",
        "models": "models"
      }
    },
    "gpt-backup": {
      "role": "analysis",
      "configSource": {
        "fileRef": "openclaw",
        "jsonPath": "$.models.providers.router-gpt-backup"
      },
      "mapping": {
        "baseUrl": "baseUrl",
        "apiKey": "apiKey",
        "api": "api",
        "headers": "headers",
        "authHeader": "authHeader",
        "models": "models"
      }
    },
    "claude": {
      "role": "analysis",
      "configSource": {
        "fileRef": "openclaw",
        "jsonPath": "$.models.providers.anyrouter"
      },
      "mapping": {
        "baseUrl": "baseUrl",
        "apiKey": "apiKey",
        "api": "api",
        "headers": "headers",
        "authHeader": "authHeader",
        "models": "models"
      }
    }
  },
  "models": {
    "gpt-main": {
      "providerRef": "gpt",
      "modelId": "gpt-5.4-xhigh"
    },
    "gpt-main-mini": {
      "providerRef": "gpt",
      "modelId": "gpt-5.4"
    },
    "claude-main": {
      "providerRef": "claude",
      "modelId": "claude-sonnet-4-6"
    }
  },
  "runtime": {
    "pipeline": ["fetch", "analyze"],
    "artifacts": {
      "fetchInput": "fetch.input.json",
      "fetchRaw": "fetch.raw.json",
      "fetchRawCsv": "fetch.raw.csv",
      "fetchTweetIndexCsv": "fetch.tweet-index.csv",
      "fetchResult": "fetch.result.json",
      "analyzeInput": "analyze.input.json",
      "analyzeResult": "analyze.result.json",
      "finalReport": "final.md"
    }
  }
}
